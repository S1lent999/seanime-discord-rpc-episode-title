{
  "id": "discord-rpc-episode-title",
  "version": "1.2.0",
  "name": "Discord RPC Episode Title",
  "description": "Shows anime episode title with custom formats in Discord RPC",
  "author": "S1lent999",
  "type": "plugin",
  "language": "typescript",
  "manifestURI": "https://raw.githubusercontent.com/S1lent999/seanime-discord-rpc-episode-title/refs/heads/dev/discord-rpc-episode-title.json",
  "payloadURI": "https://raw.githubusercontent.com/S1lent999/seanime-discord-rpc-episode-title/refs/heads/dev/discord-rpc-episode-title.ts",
  "icon": "https://raw.githubusercontent.com/S1lent999/seanime-discord-rpc-episode-title/refs/heads/dev/discord-logo.jpg",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": ["discord", "storage"]
    }
  },
  "userConfig": {
    "requiresConfig": false,
    "version": 1,
    "fields": [
      {
        "name": "disableLink",
        "label": "Disable Anilist link from title",
        "type": "switch",
        "default": "true"
      },
      {
        "name": "showEpisodeNumber",
        "label": "Show episode number",
        "type": "switch",
        "default": "true"
      },
      {
        "name": "displayFormat",
        "label": "Display Format",
        "type": "select",
        "default": "seasonEpisodeTitle",
        "options": [
          { "label": "S01E05 - Title", "value": "seasonEpisodeTitle" },
          { "label": "Episode 5 - Title", "value": "episodeTitle" },
          { "label": "S01E05", "value": "seasonEpisode" }
        ]
      }
    ]
  }
}
